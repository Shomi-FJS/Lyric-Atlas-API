# ===========================================
# Lyric Atlas API 环境变量配置
# ===========================================

# 外部网易云音乐 API 地址
# 用于获取歌词的外部 API 服务
EXTERNAL_NCM_API_URL=https://neteasecloudmusicapienhanced.vercel.app/lyric/new

# 服务端口
# 主 API 服务监听端口，默认 3000
PORT=3000

# Prisma 数据库连接地址
# 用于连接歌词仓库数据库
# 建议使用默认值，如需自定义仓库请修改此地址
PRISMA_DATABASE_URL="prisma+postgres://github.com/amll-dev/amll-ttml-db"

# 控制台日志语言配置
# 可选值: zh (中文), en (英文)
# 默认为中文
# 仅影响后端控制台日志输出语言
LOG_LANGUAGE=zh
